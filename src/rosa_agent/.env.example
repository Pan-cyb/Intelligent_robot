OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1
ASR_RECORD_DEVICE=RDPSource
ASR_RECORD_SECONDS=5

# TTS does not fall back to OPENAI_* because chat providers may not support /audio/speech.
TTS_API_KEY=
TTS_BASE_URL=https://api.xiaomimimo.com/v1
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=mimo_default
TTS_FORMAT=wav
TTS_PLAYER=paplay
TTS_ENABLED=0

ROS_SETUP=/opt/ros/humble/setup.bash
ROSA_WORKSPACE=/home/pan/Intelligent_robot
ROSA_RUNTIME_DIR=/home/pan/Intelligent_robot/runtime/rosa_agent
