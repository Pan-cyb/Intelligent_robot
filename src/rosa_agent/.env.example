OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1
ASR_RECORD_DEVICE=RDPSource
ASR_RECORD_SECONDS=5
ASR_VAD_THRESHOLD=700
ASR_VAD_ADAPTIVE=1
ASR_VAD_WARMUP_MS=500
ASR_VAD_CALIBRATE_MS=1000
ASR_VAD_MARGIN=900
ASR_VAD_RELEASE_MARGIN=400
ASR_VAD_DEBUG=0
ASR_VAD_START_FRAMES=2
ASR_VAD_SILENCE_MS=900
ASR_VAD_PRE_ROLL_MS=300
ASR_VAD_MAX_SECONDS=8
# 0 means wait forever for speech.
ASR_VAD_LISTEN_TIMEOUT_SEC=0
ASR_COMMAND_LISTEN_TIMEOUT_SEC=15
ASR_COMMAND_WINDOW_SEC=25
ASR_POST_TTS_COOLDOWN_SEC=0.8

# WSLg PulseAudio
AUDIO_BACKEND=pulse
AUDIO_INPUT_DEVICE=RDPSource
AUDIO_OUTPUT_DEVICE=
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=wav

# RDK X5 / Linux ALSA
# AUDIO_BACKEND=alsa
# AUDIO_INPUT_DEVICE=plughw:1,0
# AUDIO_OUTPUT_DEVICE=plughw:2,0
# AUDIO_SAMPLE_RATE=16000
# AUDIO_CHANNELS=1
# AUDIO_FORMAT=wav
# TTS_PLAYER=aplay

# TTS does not fall back to OPENAI_* because chat providers may not support /audio/speech.
TTS_API_KEY=
TTS_BASE_URL=https://api.xiaomimimo.com/v1
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=mimo_default
TTS_FORMAT=wav
TTS_PLAYER=paplay
TTS_ENABLED=0

ROS_SETUP=/opt/ros/humble/setup.bash
ROSA_WORKSPACE=/home/pan/Intelligent_robot
ROSA_RUNTIME_DIR=/home/pan/Intelligent_robot/runtime/rosa_agent
